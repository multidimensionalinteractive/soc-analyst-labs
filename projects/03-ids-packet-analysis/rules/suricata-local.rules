# Local lab rules for safe IDS testing.
# Use only in a controlled lab and tune before production use.

alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"LAB Suspicious scripted user agent"; flow:established,to_server; http.user_agent; content:"python-requests"; nocase; classtype:trojan-activity; sid:1000001; rev:1;)

alert dns $HOME_NET any -> any any (msg:"LAB Possible high entropy DNS label"; dns.query; pcre:"/([a-z0-9]{20,})\./i"; classtype:bad-unknown; sid:1000002; rev:1;)

alert tcp $HOME_NET any -> $EXTERNAL_NET 4444 (msg:"LAB Outbound connection to suspicious port 4444"; flow:to_server; classtype:policy-violation; sid:1000003; rev:1;)
